# Clasificación Multiclase de Tipos de Ojos

Este notebook está diseñado para desarrollar un modelo de clasificación multiclase capaz de identificar diferentes tipos de ojos a partir de imágenes. Los tipos de ojos a clasificar son: 'almendrados', 'saltones', 'juntos', 'pequeños', 'asiáticos', 'caídos' y 'encapotados'.

## 1. Importar Librerías Necesarias
"""

import tensorflow as tf
from tensorflow.keras import layers, models
from tensorflow.keras.preprocessing.image import ImageDataGenerator
import numpy as np
import matplotlib.pyplot as plt
import os
import shutil
from google.colab import drive

"""## 2. Carga de Datos desde Google Drive

Aquí se montará Google Drive para acceder a las imágenes y la ruta donde se encuentra el datasets de imágenes.
"""

# Montar Google Drive
drive.mount('/content/drive')

# Ruta imágenes en Google Drive
data_dir = '/content/drive/MyDrive/DataSet/'

# Tipos de ojos (clases)
eyes_types = [
    'ojos_almendrados',
    'ojos_saltones',
    'ojos_juntos',
    'ojos_pequeños',
    'ojos_asiáticos',
    'ojos_caídos',
    'ojos_encapotados'
]

# Verificación simple de la existencia de la carpeta
if not os.path.exists(data_dir):
    print(f"¡Advertencia: La ruta '{data_dir}' no existe! Por favor, verifica y actualiza la ruta.")
else:
    print(f"Directorio de datos encontrado: {data_dir}")
    # Aquí podrías listar las subcarpetas para verificar que tus clases están presentes
    print("Subdirectorios (clases) esperados:", os.listdir(data_dir))

import os

data_dir = '/content/drive/MyDrive/DataSet/TRAIN/'
clases = ['ojos_almendrados', 'ojos_saltones', 'ojos_juntos', 'ojos_pequeños',
          'ojos_asiáticos', 'ojos_caídos', 'ojos_encapotados']

print("📊 Distribución de imágenes por clase:")
total = 0
for clase in clases:
    ruta = os.path.join(data_dir, clase)
    if os.path.exists(ruta):
        imagenes = [f for f in os.listdir(ruta) if f.lower().endswith(('.png','.jpg','.jpeg'))]
        cantidad = len(imagenes)
        total += cantidad
        print(f"  {clase}: {cantidad} imágenes")
    else:
        print(f"  {clase}: CARPETA NO ENCONTRADA")

print(f"\n✅ Total de imágenes: {total}")

"""## 3. Preprocesamiento de Datos y Aumento de Datos

Se utilizará `ImageDataGenerator` para cargar las imágenes, redimensionarlas a un tamaño uniforme, normalizar los valores de los píxeles y aplicar técnicas de aumento de datos para mejorar la robustez del modelo.
"""

# Parámetros optimizados para Transfer Learning
img_height, img_width = 224, 224  # Tamaño óptimo para modelos preentrenados
batch_size = 8  # Reducido porque tienes pocas imágenes por lote

train_datagen = ImageDataGenerator(
    rescale=1./255,
    rotation_range=10,          # Reducido: los ojos nunca están extremadamente rotados
    width_shift_range=0.1,      # Desplazamiento horizontal leve
    height_shift_range=0.05,    # Muy bajo para no perder el ojo del encuadre
    shear_range=0.1,
    zoom_range=0.15,            # Zoom moderado para simular fotos más cerca/lejos
    horizontal_flip=True,       # ¡Esencial! Un ojo izquierdo volteado parece uno derecho
    fill_mode='nearest',
    validation_split=0.2
)


# Generador para el conjunto de entrenamiento
train_generator = train_datagen.flow_from_directory(
    data_dir,
    target_size=(img_height, img_width),
    batch_size=batch_size,
    class_mode='categorical',   # Para clasificación multiclase
    subset='training',
    classes=eyes_types
)

# Generador para el conjunto de validación
validation_generator = train_datagen.flow_from_directory(
    data_dir,
    target_size=(img_height, img_width),
    batch_size=batch_size,
    class_mode='categorical',
    subset='validation',
    classes=eyes_types
)

print(f"Clases encontradas: {train_generator.class_indices}")
num_classes = len(train_generator.class_indices)

"""## 4. Definición del Modelo (Red Neuronal Convolucional - CNN)

Una CNN es ideal para tareas de clasificación de imágenes. Aquí se define una arquitectura básica con capas convolucionales, de pooling y densas. Puedes ajustar esta arquitectura según la complejidad de tu dataset y los resultados que obtengas.
"""

# Cargar la base de MobileNetV2 preentrenada con ImageNet, omitiendo la capa final de clasificación
base_model = tf.keras.applications.MobileNetV2(
    input_shape=(img_height, img_width, 3),
    include_top=False,
    weights='imagenet'
)

# Congelar los pesos del modelo base para que no pierda lo que ya aprendió
base_model.trainable = False

# Construir tu clasificador encima del modelo base
model = models.Sequential([
    base_model,
    layers.GlobalAveragePooling2D(), # Reduce las dimensiones eficazmente
    layers.Dense(128, activation='relu'),
    layers.Dropout(0.4),             # Controla el sobreajuste (overfitting)
    layers.Dense(num_classes, activation='softmax') # Tus 7 clases de ojos
])

model.summary()

"""## 5. Compilación y Entrenamiento del Modelo

Se compila el modelo especificando un optimizador, una función de pérdida (categorical_crossentropy para clasificación multiclase) y métricas. Luego, se entrena el modelo usando los generadores de datos.
"""

model.compile(
    optimizer='adam',
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

epochs = 20 # épocas

history = model.fit(
    train_generator,
    epochs=epochs,
    validation_data=validation_generator
)

"""## 6. Evaluación del Modelo

Es importante evaluar el rendimiento del modelo en un conjunto de datos de prueba independiente (no utilizado durante el entrenamiento o la validación) para tener una estimación realista de su capacidad de generalización.
"""

# test_datagen = ImageDataGenerator(rescale=1./255)
# test_generator = test_datagen.flow_from_directory(
#     '/content/drive/MyDrive/ruta/a/tus/imagenes_de_ojos/test',
#     target_size=(img_height, img_width),
#     batch_size=batch_size,
#     class_mode='categorical',
#     classes=eyes_types
# )

# loss, accuracy = model.evaluate(test_generator)
# print(f"Pérdida en el conjunto de prueba: {loss}")
# print(f"Exactitud en el conjunto de prueba: {accuracy}")

# Visualizar el rendimiento del entrenamiento
plt.figure(figsize=(12, 4))

plt.subplot(1, 2, 1)
plt.plot(history.history['accuracy'], label='Training Accuracy')
plt.plot(history.history['val_accuracy'], label='Validation Accuracy')
plt.legend(loc='lower right')
plt.title('Training and Validation Accuracy')

plt.subplot(1, 2, 2)
plt.plot(history.history['loss'], label='Training Loss')
plt.plot(history.history['val_loss'], label='Validation Loss')
plt.legend(loc='upper right')
plt.title('Training and Validation Loss')
plt.show()

"""## 7. Predicción con Nuevas Imágenes

Una vez que el modelo esté entrenado, puedes usarlo para predecir el tipo de ojo de nuevas imágenes. Este es un ejemplo de cómo podrías cargar y preprocesar una sola imagen para la predicción.
"""

from tensorflow.keras.preprocessing import image

def predict_eye_type(image_path):
    img = image.load_img(image_path, target_size=(img_height, img_width))
    img_array = image.img_to_array(img)
    img_array = np.expand_dims(img_array, axis=0) # Crear un batch de una sola imagen
    img_array /= 255.0 # Normalizar como se hizo en el entrenamiento

    predictions = model.predict(img_array)
    predicted_class_index = np.argmax(predictions[0])
    predicted_eye_type = eyes_types[predicted_class_index]
    confidence = predictions[0][predicted_class_index]

    plt.imshow(img)
    plt.title(f"Predicción: {predicted_eye_type} (Confianza: {confidence:.2f})")
    plt.axis('off')
    plt.show()

    return predicted_eye_type, confidence

# Ejemplo de uso (asegúrate de que esta imagen exista en tu Drive)
sample_image_path = '/content/drive/MyDrive/DataSet/ojos_asiáticos/r117.jpg'
if os.path.exists(sample_image_path):
     predicted_type, conf = predict_eye_type(sample_image_path)
     print(f"La imagen es de tipo {predicted_type} con una confianza de {conf:.2f}")
else:
     print(f"¡Advertencia: La imagen de ejemplo '{sample_image_path}' no existe! Por favor, verifica la ruta.")

print("Para predecir, carga una imagen de prueba.")

def suggest_lashes_design(eye_type):
    suggestions = {
        'ojos_almendrados': 'Un "Cat Eye" o un look "Natural" son opciones versátiles que realzan la forma.',
        'ojos_saltones': 'Un "Cat Eye" sutil o un look "Natural" con tonos más oscuros en el párpado móvil pueden ayudar a equilibrar.',
        'ojos_juntos': 'El "Cat Eye" es ideal para alargar la mirada y crear la ilusión de ojos más separados.',
        'ojos_pequeños': 'Un look "Dolly" o "Natural" con delineado delgado y pestañas marcadas puede abrir la mirada.',
        'ojos_asiáticos': 'El "Cat Eye" o el estilo "Ardilla" pueden definir y alargar la forma, adaptándose a la estructura del párpado.',
        'ojos_caídos': 'Un "Cat Eye" o "Ardilla" con un levantamiento en la esquina exterior es perfecto para levantar la mirada.',
        'ojos_encapotados': 'Un "Cat Eye" o el estilo "Ardilla" son excelentes para crear definición y visibilidad del delineado por encima del pliegue.'
    }
    return suggestions.get(eye_type, 'Para este tipo de ojo, un estilo "Natural" siempre es una buena base, o explora el "Cat Eye" y "Ardilla" para un efecto dramático.')

print('\nSugerencia de diseño de Pestañas:')
print(suggest_lashes_design(os.path.exists(sample_image_path)))

"""#Sugerencias de Pestañas

Basándonos en la clasificación de tu imagen, aquí te dejo algunas ideas:

*   **Dolly Eyes:** Un look que busca agrandar y redondear la mirada, con pestañas prominentes en el centro.
*   **Cat Eye:** Alarga y eleva la mirada hacia las sienes, creando un efecto felino y sofisticado.
*   **Ardilla (Squirrel Eye):** Similar al Cat Eye pero con un enfoque en alargar la esquina externa del ojo sin un ala tan pronunciada, dando una forma más suave y alargada.
*   **Natural:** Maquillaje minimalista que realza la belleza natural del ojo con tonos neutros y una definición sutil.
"""

from flask import Flask, request, jsonify, render_template
import tensorflow as tf
import numpy as np
from PIL import Image
import io
import os

app = Flask(__name__)

# 1. CONFIGURACIÓN (¡CÁMBIALO SEGÚN TU ENTRENAMIENTO!)
TARGET_SIZE = (224, 224)  # <--- AJUSTA AQUÍ (Ej: 128,128 o 299,299 si usaste Inception)
CLASS_NAMES = [
    'ojos_almendrados',
    'ojos_saltones',
    'ojos_juntos',
    'ojos_pequeños',
    'ojos_asiáticos',
    'ojos_caídos',
    'ojos_encapotados'
]  # <--- ASEGÚRATE QUE ESTE ORDEN COINCIDA CON EL DE TU entrenamiento

# 2. CARGAR EL MODELO (asegúrate que el archivo .h5 o .keras esté en la misma carpeta)
try:
    model = tf.keras.models.load_model('model.h5')  # Si es .keras, cámbialo
    print("✅ Modelo cargado exitosamente")
except Exception as e:
    print(f"❌ Error al cargar el modelo: {e}")
    model = None

def preprocess_image(image_bytes):
    """Convierte los bytes de la imagen a un array listo para el modelo"""
    img = Image.open(io.BytesIO(image_bytes))
    # Convertir a RGB por si acaso viene en PNG con transparencia
    if img.mode != 'RGB':
        img = img.convert('RGB')
    # Redimensionar
    img = img.resize(TARGET_SIZE)
    # Convertir a array y normalizar (si entrenaste con rescale=1./255, hazlo aquí)
    img_array = np.array(img) / 255.0  # Si NO normalizaste en entrenamiento, quita el /255.0
    # Agregar dimensión de batch
    img_array = np.expand_dims(img_array, axis=0)
    return img_array

@app.route('/')
def home():
    return render_template('index.html')

@app.route('/predict', methods=['POST'])
def predict():
    if model is None:
        return jsonify({'error': 'Modelo no cargado'}), 500

    if 'image' not in request.files:
        return jsonify({'error': 'No se envió ninguna imagen'}), 400

    file = request.files['image']
    if file.filename == '':
        return jsonify({'error': 'Nombre de archivo vacío'}), 400

    try:
        # Leer la imagen
        image_bytes = file.read()
        # Preprocesar
        processed_image = preprocess_image(image_bytes)
        # Inferencia
        predictions = model.predict(processed_image)
        # Obtener la clase con mayor probabilidad
        predicted_index = np.argmax(predictions[0])
        confidence = float(np.max(predictions[0]) * 100)
        predicted_class = CLASS_NAMES[predicted_index]

        # (Opcional) Obtener top 3 para mostrarlos
        top_3_indices = np.argsort(predictions[0])[-3:][::-1]
        top_3 = [{'clase': CLASS_NAMES[i], 'probabilidad': float(predictions[0][i] * 100)} for i in top_3_indices]

        return jsonify({
            'success': True,
            'clase': predicted_class,
            'confianza': round(confidence, 2),
            'top_3': top_3
        })
    except Exception as e:
        return jsonify({'error': str(e)}), 500

if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=5000)